# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but track .env for non-secret build-time defaults (NEXT_PUBLIC_*).
!.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
design/
.claude/skills/**/**/node_modules
.next.*
playwright-report
test-results

# lighthouse: CI output, raw reports, and stray headless-chrome profile dirs
# (chrome-launcher misresolves the temp path under WSL and writes literal
# `C:\Users\...lighthouse.*` dirs into the cwd).
.lighthouseci/
*.report.json
*.report.html
C:*

# Local-only archive of removed working docs / SpecKit (untracked reference)
.archive/

# Local-only working docs / scratch (internal reference, not shipped)
PLAINSIGHT_AUDIT.md
.codex/
