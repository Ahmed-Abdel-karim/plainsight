# Non-secret build-time defaults inlined into the client bundle (NEXT_PUBLIC_*).
# Keep secrets in .env.local, which stays gitignored.

# Gates the MapGrab E2E instrumentation in components/scene/map/map-canvas.tsx.
# Defaulting to "false" makes the guard a build-time constant, so the production
# bundle dead-code-eliminates the @mapgrab/map-interface dynamic import. Playwright
# overrides this with NEXT_PUBLIC_E2E=true in the shell at build time (a real env
# var takes precedence over .env), so E2E builds keep the instrumentation.
NEXT_PUBLIC_E2E=false
